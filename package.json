{
  "name": "exifreader",
  "version": "4.41.3",
  "description": "Library that parses Exif metadata in images.",
  "author": "Mattias Wallander <mattias@wallander.eu>",
  "repository": {
    "type": "git",
    "url": "https://github.com/mattiasw/ExifReader"
  },
  "bugs": "https://github.com/mattiasw/ExifReader/issues",
  "license": "MPL-2.0",
  "main": "dist/exif-reader.js",
  "module": "src/exif-reader.js",
  "sideEffects": false,
  "files": [
    "bin/",
    "dist/",
    "src/",
    "babel.config.json",
    "exif-reader.d.ts",
    "webpack.config.js"
  ],
  "types": "./exif-reader.d.ts",
  "bin": {
    "exifreader": "bin/cli.js"
  },
  "optionalDependencies": {
    "@xmldom/xmldom": "^0.9.10"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^9.39.5",
    "@types/node": "^26.1.1",
    "babel-loader": "^10.0.0",
    "c8": "^12.0.0",
    "chai": "^6.2.2",
    "cross-env": "^10.0.0",
    "cypress": "^15.18.1",
    "eslint": "^9.39.4",
    "eslint-plugin-cypress": "^6.4.1",
    "globals": "^17.7.0",
    "husky": "^9.0.11",
    "linkedom": "^0.18.13",
    "mocha": "^11.7.6",
    "npm-run-all2": "^9.0.2",
    "rimraf": "^5.0.5",
    "string-replace-loader": "^3.1.0",
    "terser-webpack-plugin": "^5.6.1",
    "typescript": "^7.0.2",
    "webpack": "5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^5.2.6"
  },
  "scripts": {
    "build": "node bin/build.js",
    "build:pages": "node bin/build-pages.js",
    "coverage": "c8 npm test",
    "cypress:open": "cypress open --e2e",
    "lint": "eslint .",
    "start": "cross-env NODE_ENV=development webpack serve",
    "test": "mocha --recursive \"test/unit/\"",
    "test:integration": "mocha \"test/integration/**/*-spec.js\"",
    "test:integration:update": "node test/integration/update.js",
    "test:build": "mocha test/build/test.js test/build/packaging.js",
    "test:build:custom": "mocha --bail test/build/test-custom.js",
    "test:build:update": "node test/build/update.js",
    "test:e2e:chrome": "cypress run",
    "test:e2e:firefox": "cypress run --browser firefox",
    "test:types": "tsc --noEmit --project test/types",
    "test:all": "npm-run-all2 lint test:types coverage test:e2e:chrome test:integration test:build test:build:custom",
    "pre-commit": "npm-run-all2 lint test:types coverage test:build",
    "postinstall": "node bin/build.js --only-with-config",
    "prepare": "husky"
  },
  "c8": {
    "check-coverage": true,
    "statements": 93,
    "branches": 90,
    "functions": 98,
    "lines": 93,
    "reporter": [
      "lcov",
      "text"
    ],
    "exclude": [
      "test/**"
    ]
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "Chrome >= 9",
    "Firefox >= 15",
    "IE >= 10",
    "Edge >= 12",
    "Safari >= 5.1",
    "Opera >= 12.1"
  ]
}
